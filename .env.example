# Uvicorn bind host. Use 0.0.0.0 in Docker.
HOST=0.0.0.0

# Uvicorn bind port.
PORT=8000

# External published port in docker-compose.
EXTERNAL_PORT=60080

# OpenAPI server display host.
OPENAPI_HOST=127.0.0.1

# OpenAPI server URL scheme.
OPENAPI_SCHEME=http

# Optional full OpenAPI server URL override.
# OPENAPI_SERVER_URL=http://127.0.0.1:60080
