# Uvicorn bind host. Use 0.0.0.0 in Docker.
HOST=0.0.0.0

# Uvicorn bind port.
PORT=8000

# External published port in docker-compose.
EXTERNAL_PORT=60080

# OpenAPI server display host.
OPENAPI_HOST=127.0.0.1

# OpenAPI server URL scheme.
OPENAPI_SCHEME=http

# Optional full OpenAPI server URL override.
# OPENAPI_SERVER_URL=http://127.0.0.1:60080

# Database URL (default sqlite in app if not set).
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/team_bbs

# Background notify scheduler:
# Enable/disable periodic push task.
NOTIFY_TASK_ENABLED=true
# Scan interval in seconds.
NOTIFY_TASK_INTERVAL_SECONDS=30
# Per request timeout in seconds.
NOTIFY_TASK_REQUEST_TIMEOUT_SECONDS=2
